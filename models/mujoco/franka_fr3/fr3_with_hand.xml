<mujoco model="fr3_with_hand">
  <compiler angle="radian" meshdir="franka_fr3/assets" autolimits="true"/>

  <option integrator="implicitfast"/>

  <default>
    <!-- ── Arm defaults ── -->
    <default class="fr3">
      <!-- Overwritten in joints 5, 6, and 7. -->
      <joint damping="0.21" armature="0.195" frictionloss="1.137"/>
      <default class="fr3/visual">
        <geom type="mesh" group="2" contype="0" conaffinity="0"/>
      </default>
      <default class="fr3/collision">
        <geom type="mesh" group="3" mass="0" density="0"/>
      </default>
      <site size="0.001" rgba="0.5 0.5 0.5 0.3" group="4"/>
    </default>

    <!-- ── Hand defaults ── -->
    <default class="panda">
      <material specular="0.5" shininess="0.25"/>
      <joint armature="0.1" damping="1" axis="0 0 1" range="-2.8973 2.8973"/>
      <general dyntype="none" biastype="affine" ctrlrange="-2.8973 2.8973" forcerange="-87 87"/>
      <default class="finger">
        <joint axis="0 1 0" type="slide" range="0 0.04"/>
      </default>
      <default class="panda/visual">
        <geom type="mesh" contype="0" conaffinity="0" group="2"/>
      </default>
      <default class="panda/collision">
        <geom type="mesh" group="3"/>
        <default class="fingertip_pad_collision_1">
          <geom type="box" size="0.0085 0.004 0.0085" pos="0 0.0055 0.0445" friction="1.3 0.05 0.01" condim="6"/>
        </default>
        <default class="fingertip_pad_collision_2">
          <geom type="box" size="0.003 0.002 0.003" pos="0.0055 0.002 0.05" friction="1.3 0.05 0.01" condim="6"/>
        </default>
        <default class="fingertip_pad_collision_3">
          <geom type="box" size="0.003 0.002 0.003" pos="-0.0055 0.002 0.05" friction="1.3 0.05 0.01" condim="6"/>
        </default>
        <default class="fingertip_pad_collision_4">
          <geom type="box" size="0.003 0.002 0.0035" pos="0.0055 0.002 0.0395" friction="1.3 0.05 0.01" condim="6"/>
        </default>
        <default class="fingertip_pad_collision_5">
          <geom type="box" size="0.003 0.002 0.0035" pos="-0.0055 0.002 0.0395" friction="1.3 0.05 0.01" condim="6"/>
        </default>
      </default>
    </default>
  </default>

  <asset>
    <!-- ── Arm materials ── -->
    <material name="fr3/black" rgba=".2 .2 .2 1"/>
    <material name="fr3/white" rgba="1 1 1 1"/>
    <material name="fr3/red" rgba="1 0.072272 0.039546 1"/>
    <material name="fr3/gray" rgba="0.863156 0.863156 0.863157 1"/>
    <material name="fr3/button_green" rgba="0.102241 0.571125 0.102242 1"/>
    <material name="fr3/button_red" rgba="0.520996 0.008023 0.013702 1"/>
    <material name="fr3/button_blue" rgba="0.024157 0.445201 0.737911 1"/>

    <!-- ── Arm meshes (visual) ── -->
    <mesh file="link0_0.obj"/>
    <mesh file="link0_1.obj"/>
    <mesh file="link0_2.obj"/>
    <mesh file="link0_3.obj"/>
    <mesh file="link0_4.obj"/>
    <mesh file="link0_5.obj"/>
    <mesh file="link0_6.obj"/>
    <mesh file="link1.obj"/>
    <mesh file="link2.obj"/>
    <mesh file="link3_0.obj"/>
    <mesh file="link3_1.obj"/>
    <mesh file="link4_0.obj"/>
    <mesh file="link4_1.obj"/>
    <mesh file="link5_0.obj"/>
    <mesh file="link5_1.obj"/>
    <mesh file="link5_2.obj"/>
    <mesh file="link6_0.obj"/>
    <mesh file="link6_1.obj"/>
    <mesh file="link6_2.obj"/>
    <mesh file="link6_3.obj"/>
    <mesh file="link6_4.obj"/>
    <mesh file="link6_5.obj"/>
    <mesh file="link6_6.obj"/>
    <mesh file="link6_7.obj"/>
    <mesh file="link7_0.obj"/>
    <mesh file="link7_1.obj"/>
    <mesh file="link7_2.obj"/>
    <mesh file="link7_3.obj"/>

    <!-- ── Arm meshes (collision) ── -->
    <mesh name="link0_coll" file="link0.stl"/>
    <mesh name="link1_coll" file="link1.stl"/>
    <mesh name="link2_coll" file="link2.stl"/>
    <mesh name="link3_coll" file="link3.stl"/>
    <mesh name="link4_coll" file="link4.stl"/>
    <mesh name="link5_coll" file="link5.stl"/>
    <mesh name="link6_coll" file="link6.stl"/>
    <mesh name="link7_coll" file="link7.stl"/>

    <!-- ── Hand materials ── -->
    <material class="panda" name="panda/white"     rgba="1 1 1 1"/>
    <material class="panda" name="panda/off_white" rgba="0.901961 0.921569 0.929412 1"/>
    <material class="panda" name="panda/black"     rgba="0.25 0.25 0.25 1"/>

    <!-- ── Hand meshes ── -->
    <mesh name="hand_c"  file="hand.stl"/>
    <mesh name="hand_0"  file="hand_0.obj"/>
    <mesh name="hand_1"  file="hand_1.obj"/>
    <mesh name="hand_2"  file="hand_2.obj"/>
    <mesh name="hand_3"  file="hand_3.obj"/>
    <mesh name="hand_4"  file="hand_4.obj"/>
    <mesh name="finger_0" file="finger_0.obj"/>
    <mesh name="finger_1" file="finger_1.obj"/>
  </asset>

  <worldbody>
    <body name="base" childclass="fr3">
      <body name="fr3_link0">
        <geom mesh="link0_0" material="fr3/black" class="fr3/visual"/>
        <geom mesh="link0_1" material="fr3/white" class="fr3/visual"/>
        <geom mesh="link0_2" material="fr3/white" class="fr3/visual"/>
        <geom mesh="link0_3" material="fr3/white" class="fr3/visual"/>
        <geom mesh="link0_4" material="fr3/white" class="fr3/visual"/>
        <geom mesh="link0_5" material="fr3/red"   class="fr3/visual"/>
        <geom mesh="link0_6" material="fr3/black" class="fr3/visual"/>
        <geom name="fr3_link0_collision" mesh="link0_coll" class="fr3/collision"/>
        <body name="fr3_link1" pos="0 0 0.333">
          <inertial pos="4.128e-07 -0.0181251 -0.0386036" quat="0.998098 -0.0605364 0.00380499 0.0110109" mass="2.92747"
            diaginertia="0.0239286 0.0227246 0.00610634"/>
          <joint name="fr3_joint1" axis="0 0 1" range="-2.7437 2.7437" actuatorfrcrange="-87 87"/>
          <geom name="fr3_link1_collision" class="fr3/collision" mesh="link1_coll"/>
          <geom material="fr3/white" mesh="link1" class="fr3/visual"/>
          <body name="fr3_link2" quat="1 -1 0 0">
            <inertial pos="0.00318289 -0.0743222 0.00881461" quat="0.502599 0.584437 -0.465998 0.434366" mass="2.93554"
              diaginertia="0.0629567 0.0411924 0.0246371"/>
            <joint name="fr3_joint2" axis="0 0 1" range="-1.7837 1.7837" actuatorfrcrange="-87 87"/>
            <geom material="fr3/white" mesh="link2" class="fr3/visual"/>
            <geom name="fr3_link2_collision" class="fr3/collision" mesh="link2_coll"/>
            <body name="fr3_link3" pos="0 -0.316 0" quat="1 1 0 0">
              <inertial pos="0.0407016 -0.00482006 -0.0289731" quat="0.921025 -0.244161 0.155272 0.260745" mass="2.2449"
                diaginertia="0.0267409 0.0189869 0.0171587"/>
              <joint name="fr3_joint3" axis="0 0 1" range="-2.9007 2.9007" actuatorfrcrange="-87 87"/>
              <geom mesh="link3_0" material="fr3/white" class="fr3/visual"/>
              <geom mesh="link3_1" material="fr3/black" class="fr3/visual"/>
              <geom name="fr3_link3_collision" class="fr3/collision" mesh="link3_coll"/>
              <body name="fr3_link4" pos="0.0825 0 0" quat="1 1 0 0">
                <inertial pos="-0.0459101 0.0630493 -0.00851879" quat="0.438018 0.803311 0.00937812 0.403414"
                  mass="2.6156" diaginertia="0.05139 0.0372717 0.0160047"/>
                <joint name="fr3_joint4" axis="0 0 1" range="-3.0421 -0.1518" actuatorfrcrange="-87 87"/>
                <geom mesh="link4_0" material="fr3/white" class="fr3/visual"/>
                <geom mesh="link4_1" material="fr3/black" class="fr3/visual"/>
                <geom name="fr3_link4_collision" class="fr3/collision" mesh="link4_coll"/>
                <body name="fr3_link5" pos="-0.0825 0.384 0" quat="1 -1 0 0">
                  <inertial pos="-0.00160396 0.0292536 -0.0972966" quat="0.919031 0.125604 0.0751531 -0.366003"
                    mass="2.32712" diaginertia="0.0579335 0.0449144 0.0130634"/>
                  <joint name="fr3_joint5" axis="0 0 1" range="-2.8065 2.8065" actuatorfrcrange="-12 12"
                    armature="0.074" frictionloss="0.763"/>
                  <geom mesh="link5_0" material="fr3/white" class="fr3/visual"/>
                  <geom mesh="link5_1" material="fr3/white" class="fr3/visual"/>
                  <geom mesh="link5_2" material="fr3/black" class="fr3/visual"/>
                  <geom name="fr3_link5_collision" class="fr3/collision" mesh="link5_coll"/>
                  <body name="fr3_link6" quat="1 1 0 0">
                    <inertial pos="0.0597131 -0.0410295 -0.0101693" quat="0.621301 0.552665 0.510011 0.220081"
                      mass="1.81704" diaginertia="0.0175039 0.0161123 0.00193529"/>
                    <joint name="fr3_joint6" axis="0 0 1" range="0.5445 4.5169" actuatorfrcrange="-12 12"
                      armature="0.074" frictionloss="0.44"/>
                    <geom mesh="link6_0" material="fr3/button_green" class="fr3/visual"/>
                    <geom mesh="link6_1" material="fr3/white"        class="fr3/visual"/>
                    <geom mesh="link6_2" material="fr3/white"        class="fr3/visual"/>
                    <geom mesh="link6_3" material="fr3/gray"         class="fr3/visual"/>
                    <geom mesh="link6_4" material="fr3/button_red"   class="fr3/visual"/>
                    <geom mesh="link6_5" material="fr3/white"        class="fr3/visual"/>
                    <geom mesh="link6_6" material="fr3/black"        class="fr3/visual"/>
                    <geom mesh="link6_7" material="fr3/button_blue"  class="fr3/visual"/>
                    <geom name="fr3_link6_collision" class="fr3/collision" mesh="link6_coll"/>
                    <body name="fr3_link7" pos="0.088 0 0" quat="1 1 0 0">
                      <inertial pos="0.00452258 0.00862619 -0.0161633" quat="0.727579 0.0978688 -0.24906 0.63168"
                        mass="0.627143" diaginertia="0.000223836 0.000223642 5.64132e-07"/>
                      <joint name="fr3_joint7" axis="0 0 1" range="-3.0159 3.0159" actuatorfrcrange="-12 12"
                        armature="0.074" frictionloss="0.248"/>
                      <geom mesh="link7_0" material="fr3/black" class="fr3/visual"/>
                      <geom mesh="link7_1" material="fr3/white" class="fr3/visual"/>
                      <geom mesh="link7_2" material="fr3/white" class="fr3/visual"/>
                      <geom mesh="link7_3" material="fr3/black" class="fr3/visual"/>
                      <geom name="fr3_link7_collision" class="fr3/collision" mesh="link7_coll"/>
                      <site name="attachment_site" pos="0 0 0.107"/>

                      <!-- ══════════════════════════════════════════════
                           Hand attached at the flange (attachment_site)
                           pos="0 0 0.107" is already baked into link7,
                           so the hand body sits at the flange with no
                           additional offset needed.
                           ══════════════════════════════════════════════ -->
                      <body name="hand" childclass="panda" pos="0 0 0.107" quat="0 0 0 1">
                        <inertial mass="0.73" pos="-0.01 0 0.03" diaginertia="0.001 0.0025 0.0017"/>
                        <geom mesh="hand_0" material="panda/off_white" class="panda/visual"/>
                        <geom mesh="hand_1" material="panda/black"     class="panda/visual"/>
                        <geom mesh="hand_2" material="panda/black"     class="panda/visual"/>
                        <geom mesh="hand_3" material="panda/white"     class="panda/visual"/>
                        <geom mesh="hand_4" material="panda/off_white" class="panda/visual"/>
                        <geom mesh="hand_c" class="panda/collision"/>
                        <body name="left_finger" pos="0 0 0.0584">
                          <inertial mass="0.015" pos="0 0 0" diaginertia="2.375e-6 2.375e-6 7.5e-7"/>
                          <joint name="finger_joint1" class="finger"/>
                          <geom mesh="finger_0" material="panda/off_white" class="panda/visual"/>
                          <geom mesh="finger_1" material="panda/black"     class="panda/visual"/>
                          <geom mesh="finger_0" class="panda/collision"/>
                          <geom class="fingertip_pad_collision_1"/>
                          <geom class="fingertip_pad_collision_2"/>
                          <geom class="fingertip_pad_collision_3"/>
                          <geom class="fingertip_pad_collision_4"/>
                          <geom class="fingertip_pad_collision_5"/>
                        </body>
                        <body name="right_finger" pos="0 0 0.0584" quat="0 0 0 1">
                          <inertial mass="0.015" pos="0 0 0" diaginertia="2.375e-6 2.375e-6 7.5e-7"/>
                          <joint name="finger_joint2" class="finger"/>
                          <geom mesh="finger_0" material="panda/off_white" class="panda/visual"/>
                          <geom mesh="finger_1" material="panda/black"     class="panda/visual"/>
                          <geom mesh="finger_0" class="panda/collision"/>
                          <geom class="fingertip_pad_collision_1"/>
                          <geom class="fingertip_pad_collision_2"/>
                          <geom class="fingertip_pad_collision_3"/>
                          <geom class="fingertip_pad_collision_4"/>
                          <geom class="fingertip_pad_collision_5"/>
                        </body>
                      </body>

                    </body>
                  </body>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <actuator>
    <!-- Arm -->
    <motor name="tau1" joint="fr3_joint1" ctrlrange="-87 87"  forcerange="-87 87"/>
    <motor name="tau2" joint="fr3_joint2" ctrlrange="-87 87"  forcerange="-87 87"/>
    <motor name="tau3" joint="fr3_joint3" ctrlrange="-87 87"  forcerange="-87 87"/>
    <motor name="tau4" joint="fr3_joint4" ctrlrange="-87 87"  forcerange="-87 87"/>
    <motor name="tau5" joint="fr3_joint5" ctrlrange="-12 12"  forcerange="-12 12"/>
    <motor name="tau6" joint="fr3_joint6" ctrlrange="-12 12"  forcerange="-12 12"/>
    <motor name="tau7" joint="fr3_joint7" ctrlrange="-12 12"  forcerange="-12 12"/>
    <!-- Hand (gripper) -->
    <general class="panda" name="actuator8" tendon="split" forcerange="-100 100" ctrlrange="0 255"
      gainprm="0.01568627451 0 0" biasprm="0 -100 -10"/>
  </actuator>

  <contact>
    <exclude body1="fr3_link0"   body2="fr3_link1"/>
    <exclude body1="hand"        body2="left_finger"/>
    <exclude body1="hand"        body2="right_finger"/>
  </contact>

  <tendon>
    <fixed name="split">
      <joint joint="finger_joint1" coef="0.5"/>
      <joint joint="finger_joint2" coef="0.5"/>
    </fixed>
  </tendon>

  <equality>
    <joint joint1="finger_joint1" joint2="finger_joint2" solimp="0.95 0.99 0.001" solref="0.005 1"/>
  </equality>

  <keyframe>
    <!-- arm home + gripper fully open (255) -->
    <key name="home" qpos="0 0 0 -1.57079 0 1.57079 -0.7853 0.04 0.04" ctrl="0 0 0 -1.57079 0 1.57079 -0.7853 255"/>
  </keyframe>

</mujoco>
